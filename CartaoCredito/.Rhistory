cat("Instalando pacotes ausentes:", paste(pacotes_ausentes, collapse = ", "), "\n")
install.packages(pacotes_ausentes, dependencies = TRUE)
} else {
cat("Todos os pacotes já estão instalados!\n")
}
# =========================================================
# 2. Carregar as bibliotecas
# =========================================================
library(readxl)
library(caret)
library(randomForest)
library(pROC)
library(dplyr)
library(smotefamily)
library(doParallel)
# Definir a semente global conforme solicitado
set.seed(123)
# ---------------------------------------------------------
# ETAPA 1: IMPORTAÇÃO E PREPARAÇÃO DOS DADOS
# ---------------------------------------------------------
cat("Etapa 1: Importando e limpando dados...\n")
# Importa os dados pulando a primeira linha (que contém X1, X2...)
dados <- read_excel("default of credit card clients.xls", skip = 1)
# Renomeia a variável alvo  para facilitar a manipulação
colnames(dados)[ncol(dados)] <- "Default"
# Remove a coluna ID
dados <- dados %>% select(-ID)
# Tratamento Categórico
dados$EDUCATION <- as.character(dados$EDUCATION)
dados$EDUCATION[dados$EDUCATION %in% c("0", "4", "5", "6")] <- "Outros"
dados$EDUCATION <- as.factor(dados$EDUCATION)
dados$MARRIAGE <- as.character(dados$MARRIAGE)
dados$MARRIAGE[dados$MARRIAGE %in% c("0", "3")] <- "Outros"
dados$MARRIAGE <- as.factor(dados$MARRIAGE)
dados$SEX <- as.factor(dados$SEX)
# Converte a variável alvo para fator
dados$Default <- factor(dados$Default, levels = c(0, 1), labels = c("Nao", "Sim"))
# ---------------------------------------------------------
# ETAPA 1.5: FEATURE ENGINEERING AVANÇADA
# ---------------------------------------------------------
cat("Etapa 1.5: Criando novas variáveis avançadas (Atrasos e Rácio)...\n")
dados <- dados %>%
mutate(
# 1. Soma de Meses em Atraso (Score de Calote)
# Valores de PAY_ > 0 significam atraso (1=um mês, 2=dois meses, etc.)
# Contamos em quantos meses o cliente ficou inadimplente no histórico
Total_Meses_Atraso = (PAY_0 > 0) + (PAY_2 > 0) + (PAY_3 > 0) +
(PAY_4 > 0) + (PAY_5 > 0) + (PAY_6 > 0),
# 2. Rácio Pagamento / Dívida Médio (Payment-to-Bill Ratio)
# Compara a soma de tudo que ele pagou vs tudo que foi cobrado nos 6 meses
Soma_Faturas = BILL_AMT1 + BILL_AMT2 + BILL_AMT3 + BILL_AMT4 + BILL_AMT5 + BILL_AMT6,
Soma_Pagamentos = PAY_AMT1 + PAY_AMT2 + PAY_AMT3 + PAY_AMT4 + PAY_AMT5 + PAY_AMT6,
# Se a fatura é > 0, calcula o rácio. Se for <= 0, assumimos que ele não deve nada (Rácio = 1)
Racio_Pagamento_Divida = ifelse(Soma_Faturas > 0, Soma_Pagamentos / Soma_Faturas, 1)
) %>%
# Remove as colunas temporárias de soma para não gerar multicolinearidade depois
select(-Soma_Faturas, -Soma_Pagamentos)
# ---------------------------------------------------------
# ETAPA 2: PARTICIONAMENTO DOS DADOS (80/20 Estratificado)
# ---------------------------------------------------------
cat("Etapa 2: Particionando os dados (80/20)...\n")
set.seed(123)
indice_treino <- createDataPartition(dados$Default, p = 0.8, list = FALSE)
treino <- dados[indice_treino, ]
teste  <- dados[-indice_treino, ]
# ---------------------------------------------------------
# ETAPA 3: PRÉ-PROCESSAMENTO
# ---------------------------------------------------------
cat("Etapa 3: Aplicando filtros de variância nula e multicolinearidade...\n")
numericas_treino <- treino[, sapply(treino, is.numeric)]
# 3.1. Filtro de Variância Nula
nzv_cols <- nearZeroVar(numericas_treino)
if(length(nzv_cols) > 0) {
treino <- treino[, -nzv_cols]
}
# 3.2. Filtro de Multicolinearidade
numericas_treino <- treino[, sapply(treino, is.numeric)]
matriz_cor <- cor(numericas_treino, use = "pairwise.complete.obs")
altamente_correlacionadas <- findCorrelation(matriz_cor, cutoff = 0.90)
if(length(altamente_correlacionadas) > 0) {
nomes_remover <- colnames(numericas_treino)[altamente_correlacionadas]
treino <- treino[, !(colnames(treino) %in% nomes_remover)]
}
# Aplicar o mesmo recorte na base de teste
teste <- teste[, colnames(treino)]
# ---------------------------------------------------------
# ETAPA 4: SELEÇÃO DE VARIÁVEIS (RFE)
# ---------------------------------------------------------
cat("Etapa 4: Seleção de variáveis com RFE (Isso pode demorar)...\n")
cl <- makePSOCKcluster(detectCores() - 1)
registerDoParallel(cl)
X_treino <- treino %>% select(-Default)
Y_treino <- treino$Default
funcoes_rf <- rfFuncs
funcoes_rf$summary <- twoClassSummary
controle_rfe <- rfeControl(functions = funcoes_rf,
method = "cv",
number = 10,
allowParallel = TRUE)
set.seed(123)
resultado_rfe <- rfe(x = X_treino,
y = Y_treino,
sizes = c(1:15, 19),
metric = "ROC",
rfeControl = controle_rfe,
ntree = 100)
# =========================================================
# PROJETO: PREDIÇÃO DE RISCO DE CRÉDITO
# =========================================================
# Nomes : ARthur,Ricardo,Savio
# =========================================================
# 1. Verificação e Instalação Automática de Pacotes
# =========================================================
cat("Verificando pacotes necessários...\n")
pacotes_necessarios <- c("readxl", "caret", "randomForest", "pROC", "dplyr", "smotefamily", "doParallel")
# Descobre quais pacotes da lista não estão instalados na máquina
pacotes_ausentes <- pacotes_necessarios[!(pacotes_necessarios %in% installed.packages()[,"Package"])]
if(length(pacotes_ausentes) > 0) {
cat("Instalando pacotes ausentes:", paste(pacotes_ausentes, collapse = ", "), "\n")
install.packages(pacotes_ausentes, dependencies = TRUE)
} else {
cat("Todos os pacotes já estão instalados!\n")
}
# =========================================================
# 2. Carregar as bibliotecas
# =========================================================
library(readxl)
library(caret)
library(randomForest)
library(pROC)
library(dplyr)
library(smotefamily)
library(doParallel)
# Definir a semente global conforme solicitado
set.seed(123)
# ---------------------------------------------------------
# ETAPA 1: IMPORTAÇÃO E PREPARAÇÃO DOS DADOS
# ---------------------------------------------------------
cat("Etapa 1: Importando e limpando dados...\n")
# Importa os dados pulando a primeira linha (que contém X1, X2...)
dados <- read_excel("default of credit card clients.xls", skip = 1)
# Renomeia a variável alvo  para facilitar a manipulação
colnames(dados)[ncol(dados)] <- "Default"
# Remove a coluna ID
dados <- dados %>% select(-ID)
# Tratamento Categórico
dados$EDUCATION <- as.character(dados$EDUCATION)
dados$EDUCATION[dados$EDUCATION %in% c("0", "4", "5", "6")] <- "Outros"
dados$EDUCATION <- as.factor(dados$EDUCATION)
dados$MARRIAGE <- as.character(dados$MARRIAGE)
dados$MARRIAGE[dados$MARRIAGE %in% c("0", "3")] <- "Outros"
dados$MARRIAGE <- as.factor(dados$MARRIAGE)
dados$SEX <- as.factor(dados$SEX)
# Converte a variável alvo para fator
dados$Default <- factor(dados$Default, levels = c(0, 1), labels = c("Nao", "Sim"))
# ---------------------------------------------------------
# ETAPA 1.5: FEATURE ENGINEERING AVANÇADA
# ---------------------------------------------------------
cat("Etapa 1.5: Criando novas variáveis avançadas (Atrasos e Rácio)...\n")
dados <- dados %>%
mutate(
# 1. Soma de Meses em Atraso (Score de Calote)
# Valores de PAY_ > 0 significam atraso (1=um mês, 2=dois meses, etc.)
# Contamos em quantos meses o cliente ficou inadimplente no histórico
Total_Meses_Atraso = (PAY_0 > 0) + (PAY_2 > 0) + (PAY_3 > 0) +
(PAY_4 > 0) + (PAY_5 > 0) + (PAY_6 > 0),
# 2. Rácio Pagamento / Dívida Médio (Payment-to-Bill Ratio)
# Compara a soma de tudo que ele pagou vs tudo que foi cobrado nos 6 meses
Soma_Faturas = BILL_AMT1 + BILL_AMT2 + BILL_AMT3 + BILL_AMT4 + BILL_AMT5 + BILL_AMT6,
Soma_Pagamentos = PAY_AMT1 + PAY_AMT2 + PAY_AMT3 + PAY_AMT4 + PAY_AMT5 + PAY_AMT6,
# Se a fatura é > 0, calcula o rácio. Se for <= 0, assumimos que ele não deve nada (Rácio = 1)
Racio_Pagamento_Divida = ifelse(Soma_Faturas > 0, Soma_Pagamentos / Soma_Faturas, 1)
) %>%
# Remove as colunas temporárias de soma para não gerar multicolinearidade depois
select(-Soma_Faturas, -Soma_Pagamentos)
# ---------------------------------------------------------
# ETAPA 2: PARTICIONAMENTO DOS DADOS (80/20 Estratificado)
# ---------------------------------------------------------
cat("Etapa 2: Particionando os dados (80/20)...\n")
set.seed(123)
indice_treino <- createDataPartition(dados$Default, p = 0.8, list = FALSE)
treino <- dados[indice_treino, ]
teste  <- dados[-indice_treino, ]
# ---------------------------------------------------------
# ETAPA 3: PRÉ-PROCESSAMENTO
# ---------------------------------------------------------
cat("Etapa 3: Aplicando filtros de variância nula e multicolinearidade...\n")
numericas_treino <- treino[, sapply(treino, is.numeric)]
# 3.1. Filtro de Variância Nula
nzv_cols <- nearZeroVar(numericas_treino)
if(length(nzv_cols) > 0) {
treino <- treino[, -nzv_cols]
}
# 3.2. Filtro de Multicolinearidade
numericas_treino <- treino[, sapply(treino, is.numeric)]
matriz_cor <- cor(numericas_treino, use = "pairwise.complete.obs")
altamente_correlacionadas <- findCorrelation(matriz_cor, cutoff = 0.90)
if(length(altamente_correlacionadas) > 0) {
nomes_remover <- colnames(numericas_treino)[altamente_correlacionadas]
treino <- treino[, !(colnames(treino) %in% nomes_remover)]
}
# Aplicar o mesmo recorte na base de teste
teste <- teste[, colnames(treino)]
# ---------------------------------------------------------
# ETAPA 4: SELEÇÃO DE VARIÁVEIS (RFE)
# ---------------------------------------------------------
cat("Etapa 4: Seleção de variáveis com RFE (Isso pode demorar)...\n")
cl <- makePSOCKcluster(detectCores() - 1)
registerDoParallel(cl)
X_treino <- treino %>% select(-Default)
Y_treino <- treino$Default
funcoes_rf <- rfFuncs
funcoes_rf$summary <- twoClassSummary
controle_rfe <- rfeControl(functions = funcoes_rf,
method = "cv",
number = 10,
allowParallel = TRUE)
set.seed(123)
resultado_rfe <- rfe(x = X_treino,
y = Y_treino,
sizes = c(1:15, 19),
metric = "ROC",
rfeControl = controle_rfe,
ntree = 100)
vars_selecionadas <- predictors(resultado_rfe)
X_treino_rfe <- X_treino[, vars_selecionadas, drop = FALSE]
X_teste_rfe  <- teste[, vars_selecionadas, drop = FALSE]
# ---------------------------------------------------------
# ETAPA 5: MODELAGEM FINAL (RANDOM FOREST COM SMOTE)
# ---------------------------------------------------------
cat("Etapa 5: Convertendo Fatores e Treinando Random Forest + SMOTE...\n")
# 1. Dummy Vars para o SMOTE poder fazer os cálculos de distância
molde_dummies <- dummyVars(~ ., data = as.data.frame(X_treino_rfe), fullRank = TRUE)
X_treino_num <- as.data.frame(predict(molde_dummies, newdata = as.data.frame(X_treino_rfe)))
X_teste_num  <- as.data.frame(predict(molde_dummies, newdata = as.data.frame(X_teste_rfe)))
# Limpeza de nomes
colnames(X_treino_num) <- make.names(colnames(X_treino_num), unique = TRUE)
colnames(X_teste_num)  <- make.names(colnames(X_teste_num), unique = TRUE)
# 2. Configurando Treinamento
controle_treino <- trainControl(method = "cv",
number = 10,
classProbs = TRUE,
summaryFunction = twoClassSummary,
allowParallel = TRUE,
sampling = "smote")
# 3. Grade otimizada
valores_mtry <- c(2, floor(sqrt(ncol(X_treino_num))), ncol(X_treino_num))
grid_otimizacao <- expand.grid(mtry = valores_mtry)
set.seed(123)
modelo_final <- train(x = X_treino_num,
y = Y_treino,
method = "rf",
ntree = 100,
tuneGrid = grid_otimizacao,
metric = "ROC",
trControl = controle_treino)
stopCluster(cl)
registerDoSEQ()
# ---------------------------------------------------------
# ETAPA 6: AVALIAÇÃO E GRÁFICOS
# ---------------------------------------------------------
cat("Etapa 6: Calculando o desempenho final...\n")
pred_classes <- predict(modelo_final, newdata = X_teste_num)
pred_probs   <- predict(modelo_final, newdata = X_teste_num, type = "prob")
# 6.1. Matriz com Limiar Padrão (0.50)
cat("\n--- DESEMPENHO NO TESTE (Limiar 0.50) ---\n")
print(confusionMatrix(pred_classes, teste$Default, positive = "Sim"))
# 6.2. Matriz com Limiar Otimizado do Artigo (0.38)
limiar_otimizado <- 0.38
pred_classes_38 <- factor(ifelse(pred_probs$Sim > limiar_otimizado, "Sim", "Nao"), levels = c("Nao", "Sim"))
cat("\n--- DESEMPENHO NO TESTE (Limiar 0.38 - Otimizado) ---\n")
print(confusionMatrix(pred_classes_38, teste$Default, positive = "Sim"))
# 6.3. Área Sob a Curva ROC (AUC)
roc_curva <- roc(teste$Default, pred_probs$Sim)
cat("\nAUC (ROC):", auc(roc_curva), "\n")
# 6.4. GRÁFICOS
plot(varImp(modelo_final), top = 10, main = "Top 10 Variáveis (SMOTE + Eng. de Atributos)")
plot(roc_curva, col = "darkgreen", lwd = 2, main = "Curva ROC - Modelo Master")
cat("\nProcesso finalizado com sucesso!\n")
# 6.4. GRÁFICOS MATADORES
# =========================================================
par(mfrow=c(1,1)) # Garante que os gráficos ocupem a tela toda um por vez
# Gráfico 1: Importância das Variáveis
plot(varImp(modelo_final), top = 10, main = "Top 10 Variáveis (SMOTE + Eng. de Atributos)")
# Gráfico 2: Curva ROC
plot(roc_curva, col = "darkgreen", lwd = 2, main = "Curva ROC - Modelo Master")
# Gráfico 3: TRADE-OFF (Sensibilidade vs Especificidade vs Acurácia por Limiar)
# Extrai as métricas para todos os limiares possíveis usando o pacote pROC
metricas_limiares <- coords(roc_curva, x = "all", ret = c("threshold", "accuracy", "sensitivity", "specificity"))
metricas_limiares <- metricas_limiares[is.finite(metricas_limiares$threshold), ] # Remove Infinitos
# Plota a linha base (Acurácia)
plot(metricas_limiares$threshold, metricas_limiares$accuracy, type = "l", col = "blue", lwd = 3,
xlab = "Limiar de Probabilidade (Corte)", ylab = "Performance (0 a 1)",
main = "Trade-off: Acurácia x Sensibilidade x Especificidade",
ylim = c(0, 1), xlim = c(0, 1))
# Adiciona Sensibilidade e Especificidade
lines(metricas_limiares$threshold, metricas_limiares$sensitivity, col = "red", lwd = 3)
lines(metricas_limiares$threshold, metricas_limiares$specificity, col = "darkorange", lwd = 3)
# Adiciona uma grade leve para facilitar a leitura
grid(nx = NULL, ny = NULL, col = "lightgray", lty = "dotted")
# Adiciona linhas verticais marcando os nossos dois limiares testados
abline(v = 0.50, col = "black", lty = 2, lwd = 2) # Linha do limiar 0.50
abline(v = 0.38, col = "darkred", lty = 2, lwd = 2) # Linha do limiar 0.38
# Legenda bonitona
legend("bottom", inset=c(0, 0.05), legend = c("Acurácia", "Sensibilidade (Recall)", "Especificidade"),
col = c("blue", "red", "darkorange"), lwd = 3, bty = "n", horiz = TRUE, cex = 0.8)
# Textos indicando as linhas de corte
text(0.52, 0.1, "Limiar\nPadrão\n(0.50)", col = "black", cex = 0.8, pos = 4)
text(0.36, 0.1, "Limiar\nOtimizado\n(0.38)", col = "darkred", cex = 0.8, pos = 2)
cat("\nProcesso finalizado com sucesso! Veja a aba de 'Plots' no RStudio.\n")
# =========================================================
# PROJETO: PREDIÇÃO DE RISCO DE CRÉDITO
# =========================================================
